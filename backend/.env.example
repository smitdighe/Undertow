DATABASE_URL=
GROQ_API_KEY=
CEREBRAS_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=
GITHUB_WEBHOOK_SECRET=
CRON_SHARED_SECRET=
# NextAuth runs here (route handler is backend/app/api/auth/[...nextauth]).
# NEXTAUTH_URL is the PUBLIC frontend origin, since the browser reaches the API
# through the frontend's /api/* proxy rewrite.
NEXTAUTH_URL=
# Must match the frontend's NEXTAUTH_SECRET exactly.
NEXTAUTH_SECRET=
GITHUB_ID=
GITHUB_SECRET=
