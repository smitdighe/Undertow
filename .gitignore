# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Repo is a frontend/ + backend/ split, so these patterns are deliberately
# UNANCHORED (no leading slash): a leading slash pins a pattern to the repo root
# only, which would leave frontend/node_modules and frontend/.next tracked.
# Unanchored matches at any depth, covering both workspaces.

# dependencies
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# testing
coverage/

# next.js
.next/
out/

# production
build/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env
.env*.local
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Prisma custom-output leftover from the create-next-app template. Currently
# dead (backend/prisma/schema.prisma uses the default generator output), kept
# unanchored so it would cover either workspace if a custom output is ever set.
app/generated/prisma
