BACKEND_URL=
# Must match backend/.env NEXTAUTH_SECRET exactly (middleware getToken decrypts the backend-issued JWT)
NEXTAUTH_SECRET=

NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_API_BASE_URL=          # same-origin by default; only used if API is proxied/split
NEXT_PUBLIC_ENABLE_SSE_RECONNECT=true
NEXT_PUBLIC_SSE_RECONNECT_MS=3000
NEXT_PUBLIC_POLL_FALLBACK_MS=      # fallback polling interval if SSE connection drops
NEXT_PUBLIC_REDUCED_MOTION_DEFAULT=false

# Backend-only vars are NOT duplicated here — they live in backend/.env:
#   DATABASE_URL, GROQ_API_KEY, CEREBRAS_API_KEY, GEMINI_API_KEY, GEMINI_MODEL,
#   GITHUB_WEBHOOK_SECRET, CRON_SHARED_SECRET, GITHUB_ID, GITHUB_SECRET, NEXTAUTH_URL.
# Exceptions above, which the frontend genuinely needs:
#   BACKEND_URL      — next.config.mjs rewrite target.
#   NEXTAUTH_SECRET  — middleware.ts getToken() decrypts the backend-issued session JWT.
